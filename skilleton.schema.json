{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skilleton Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["skills"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "repo", "path", "ref"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 1,
            "anyOf": [{ "pattern": "^(https?|git|ssh)://.+" }, { "pattern": "^[^/\\s]+/[^/\\s]+$" }]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "uniqueItems": true
    }
  }
}
